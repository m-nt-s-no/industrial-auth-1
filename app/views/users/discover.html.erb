<div class="row mb-4">
  <div class="col-md-6 offset-md-3">
    <h1 class="display-4">
      discover

    </h1>
    
    <% if current_user == @user %>
      <p class="lead text-muted">posts liked by people you follow</p>
    <% else %>
      <p class="lead text-muted">sorry, you're not authorized to view <%= "#{@user.username}" %>'s discover page</p>
    <% end %>
  </div>
</div>

<% if current_user == @user %>
  <% @user.discover.each do |photo| %>
    <div class="row mb-4">
      <div class="col-md-6 offset-md-3">
        <%= render "photos/photo", photo: photo %>
      </div>
    </div>
  <% end %>
<% end %>
